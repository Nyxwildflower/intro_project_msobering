<%= render partial: "partials/page_title", locals: {title: "Exhibitions", page_object: @exhibitions} %>

<section class="section fixed-grid has-2-cols">
  <div class="grid">
    <% @exhibitions.each do |exhibition| %>
      <div class="cell box"><%= link_to exhibition.title, exhibition %></div>
    <% end %>
  </div>
</section>